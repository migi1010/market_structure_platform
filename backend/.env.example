APP_NAME=Miji Quant Institutional API
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
ALLOWED_ORIGINS=https://frontend-kuan-s-projects1.vercel.app,https://miji-quant.com,https://api.miji-quant.com,capacitor://localhost,ionic://localhost
CORS_WHITELIST=https://frontend-kuan-s-projects1.vercel.app,https://miji-quant.com,https://api.miji-quant.com,capacitor://localhost,ionic://localhost
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
REQUEST_TIMEOUT_SECONDS=90
QUOTE_TTL_SECONDS=900
HISTORY_TTL_SECONDS=3600
STATEMENT_TTL_SECONDS=21600
NEWS_TTL_SECONDS=1800
PROVIDER_TIMEOUT_SECONDS=12
PROVIDER_RETRY_COUNT=3
PROVIDER_RETRY_BACKOFF_SECONDS=1.25
FMP_API_KEY=
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_SERVER_KEY=

# Phase 6 local research runtime. Production defaults should remain render_safe.
MIJI_RUNTIME_MODE=render_safe
MIJI_LIGHTWEIGHT_MODE=true
MIJI_ENABLE_HEAVY_ALPHA=false
MIJI_ENABLE_HEAVY_REGIME=false
MIJI_ENABLE_THEME_FORECAST=false
MIJI_ENABLE_LEAN=false
MIJI_ENABLE_BACKGROUND_JOBS=false
MIJI_ENABLE_FEATURE_STORE=false
MIJI_FEATURE_STORE_DIR=.cache/research_store
