# ═══════════════════════════════════════════════════════════════════════
# Market Structure Platform - Phase 1 Configuration Template
# Copy to .env and fill in your credentials
# ═══════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════
# NOTIFICATION CHANNELS (可選配置 - 至少配置一個用於推送)
# ═══════════════════════════════════════════════════════════════════════

# Discord - Webhook 通知
# 創建方式: Server Settings → Integrations → Webhooks → Create Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Telegram - Bot 通知
# 創建方式: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# Email - SMTP 發送
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password  # Gmail 需要使用應用密碼
EMAIL_RECIPIENT=recipient@example.com

# ═══════════════════════════════════════════════════════════════════════
# DATA PROVIDER CONFIGURATION (可選 - yfinance 預設免費)
# ═══════════════════════════════════════════════════════════════════════

# yfinance 配置
YFINANCE_LOOKBACK_DAYS=252  # 預設 1 年交易日
YFINANCE_CACHE_DIR=./data_cache

# ═══════════════════════════════════════════════════════════════════════
# HMM MODEL CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════

HMM_N_COMPONENTS=3  # Hidden States 數量
HMM_COVARIANCE_TYPE=full  # 協方差類型
HMM_MAX_ITER=100  # 最大迭代次數
HMM_RETRAIN_DAYS=7  # 模型重新訓練週期

# ═══════════════════════════════════════════════════════════════════════
# ALPHA FACTOR ENGINE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════

# 因子權重配置 (可選 - 使用預設值)
# ALPHA_WEIGHTS_BULL=growth:0.4,momentum:0.25,quality:0.2,valuation:0.1,smart_money:0.05
# ALPHA_WEIGHTS_BEAR=quality:0.4,valuation:0.3,growth:0.1,momentum:0.1,smart_money:0.1
# ALPHA_WEIGHTS_VOLATILE=quality:0.35,valuation:0.25,growth:0.15,momentum:0.15,smart_money:0.1

# ═══════════════════════════════════════════════════════════════════════
# SMART MONEY DETECTION CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════

SMART_MONEY_VOLUME_RATIO_THRESHOLD=1.5  # 成交量比閾值
SMART_MONEY_CONSOLIDATION_THRESHOLD=0.05  # 盤整波動閾值
SMART_MONEY_MOMENTUM_THRESHOLD=0.5  # 動量閾值

# ═══════════════════════════════════════════════════════════════════════
# BUBBLE DETECTION CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════

BUBBLE_VALUATION_WEIGHT=0.3  # 估值泡沫權重
BUBBLE_MOMENTUM_WEIGHT=0.4  # 動量泡沫權重
BUBBLE_DISTRIBUTION_WEIGHT=0.3  # 出貨泡沫權重
BUBBLE_THRESHOLD=60  # 泡沫判定閾值 (0-100)

# ═══════════════════════════════════════════════════════════════════════
# UNIVERSE & STOCK SELECTION
# ═══════════════════════════════════════════════════════════════════════

# S&P 500 樣本股 (Alpha 評分用)
SP500_UNIVERSE=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,BRK.B,JNJ,V,WMT,MA,PG,COST,MCD,HD,NKE,ADBE,NFLX,CRM

# 泡沫檢測樣本 (高成長股)
BUBBLE_DETECTION_UNIVERSE=TSLA,NFLX,AMD,NVDA,SOFI,UPST,COIN,RIOT,MSTR,ROKU,LCID,CLOV,DASH,DOCN

# ═══════════════════════════════════════════════════════════════════════
# PIPELINE & SCHEDULING (GitHub Actions 環境變數)
# ═══════════════════════════════════════════════════════════════════════

# 報告目錄
REPORT_DIR=./reports

# 模型目錄
MODEL_DIR=./models

# 日誌等級
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# ═══════════════════════════════════════════════════════════════════════
# 備註
# ═══════════════════════════════════════════════════════════════════════
# 1. Discord Webhook: 前往 Discord 伺服器設定 → 整合 → Webhooks → 建立
# 2. Telegram Bot: 前往 @BotFather (https://t.me/BotFather) 建立機器人
# 3. Email 密碼: Gmail 需使用應用密碼 (https://myaccount.google.com/apppasswords)
# 4. GitHub Actions: 將敏感資訊設定在 Settings → Secrets and variables → Actions
# 5. yfinance: 無需認證，自動從 Yahoo Finance 獲取數據
# 支援: 滬深代碼(600000), 香港代碼(hk00700), 美股代碼(AAPL)
STOCK_LIST=600519,000858,hk00700,AAPL,TSLA

# ============================================================================
# Notification Channels (Optional - at least one recommended)
# ============================================================================

# Discord Webhook
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Email
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECEIVER=your_email@gmail.com
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Enterprise WeChat (企業微信)
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY

# Feishu (飛書)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_TOKEN

# Slack Bot
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL_ID=C123456789

# ============================================================================
# Data Source Configuration
# ============================================================================

# 優先數據源 (支援: yfinance, akshare, tushare)
DATA_PROVIDER_PRIORITY=yfinance,akshare

# Tushare Token (用於獲取中文數據)
TUSHARE_TOKEN=your_tushare_token

# AKShare (無需配置, 開源免費)
# AKSHARE 自動支援

# ============================================================================
# System Configuration
# ============================================================================

# 日誌等級 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 時區
TZ=Asia/Shanghai

# 臨時目錄
TEMP_DIR=/tmp/market_analysis

# 數據緩存目錄
CACHE_DIR=./cache

# 分析結果保存目錄
RESULTS_DIR=./results

# ============================================================================
# Feature Flags
# ============================================================================

# 啟用市場狀態偵測
ENABLE_REGIME_DETECTION=true

# 啟用風險警報
ENABLE_RISK_ALERTS=true

# 啟用催化因素識別
ENABLE_CATALYST_DETECTION=true

# 啟用 Agent 策略問股 (需要配置 LLM)
ENABLE_AGENT_MODE=true

# ============================================================================
# Advanced Settings
# ============================================================================

# 連接超時時間 (秒)
CONNECT_TIMEOUT=10

# 讀取超時時間 (秒)
READ_TIMEOUT=30

# 最大重試次數
MAX_RETRIES=3

# 重試延遲 (秒)
RETRY_DELAY=5

# 並發數量
MAX_CONCURRENT=5

# ============================================================================
# Development Only
# ============================================================================

# 調試模式
DEBUG=false

# 乾跑模式 (不實際發送通知)
DRY_RUN=false

# API 代理 (可選)
HTTP_PROXY=
HTTPS_PROXY=

# ============================================================================
# Notes / 說明
# ============================================================================

# 1. 獲取 API Key
#    - Anspire: https://open.anspire.cn
#    - AIHubMix: https://aihubmix.com
#    - OpenAI: https://platform.openai.com/api-keys
#
# 2. 配置通知
#    - Discord: 創建 Webhook (服務器設置 > 整合 > 新增 Webhook)
#    - Telegram: 創建 Bot (@BotFather), 獲取 Token 和 Chat ID
#    - Email: Gmail 需要使用應用專用密碼
#    - WeChat: 創建機器人得到 Webhook URL
#
# 3. 數據源
#    - YFinance: 無需認證 (美股、港股、部分中文代碼)
#    - AKShare: 開源免費 (A股數據)
#    - Tushare: 可選 (更詳細的 A股數據)
#
# 4. GitHub Actions 部署
#    - 在 Repository Settings > Secrets and variables > Actions 中添加以上配置
#    - 工作流會自動在工作日 18:00 執行 (北京時間)
